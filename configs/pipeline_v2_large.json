{
  "output_dir": "results/v2_large_dataset",
  "fasta_path": "data/fasta/refseq_genomes",
  "bio": {
    "min_sequence_length": 90,
    "max_sequence_length": 12000,
    "fragment_length": 1800,
    "fragment_stride": 900,
    "max_fragments_per_record": 100,
    "kmer_sizes": [1, 2, 3],
    "max_kmer_features": 84,
    "use_vienna_rna": true,
    "use_protein_features": true,
    "translate_longest_orf": true,
