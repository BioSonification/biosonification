    "esm_model_name": "facebook/esm2_t33_650M_UR50D",
    "esm_feature_dim": 128,
    "esm_max_length": 512,
    "esm_device": "auto",
    "embedding_dim": 384
  },
  "music": {
    "midi_dirs": [
      "data/midi/POP909/POP909",
      "data/midi/maestro-v3.0.0"
    ],
    "use_music21_corpus_fallback": false,
    "music21_composers": [],
    "max_music21_files": 0,
