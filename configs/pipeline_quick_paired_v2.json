{
  "pipeline": {
    "seed": 42,
    "device": "cuda",
    "output_dir": "results/quick_paired_run_v2"
  },
  "extraction": {
    "kmer_sizes": [
      1,
      2,
      3
    ],
    "window_size": 1000,
    "stride": 500,
    "min_sequence_length": 100
  },
  "sonification": {
    "tempo_range": [
      60,
      180
    ],
    "pitch_range": [
      36,
      96
    ],
    "key_mapping": "cycle_of_fifths",
    "chord_complexity_levels": 5,
    "calibrate": true
  },
  "data": {
    "train_split": 0.7,
    "val_split": 0.15,
    "test_split": 0.15,
    "min_midi_duration": 30,
    "max_midi_duration": 300
  },
  "model": {
    "d_model": 256,
    "n_heads": 8,
    "n_layers": 6,
    "dropout": 0.1,
    "max_seq_len": 512,
    "bio_vector_dim": 128,
    "gumbel_temp_init": 1.0,
    "gumbel_temp_min": 0.1,
    "gumbel_decay": 0.9999
  },
  "training": {
    "batch_size": 8,
    "learning_rate": 0.0001,
    "weight_decay": 0.01,
    "epochs": 1,
    "grad_clip": 1.0,
    "aux_loss_weight": 0.1,
    "early_stopping_patience": 2
  },
  "evaluation": {
    "n_samples_per_bio": 2,
    "significance_level": 0.05,
    "n_permutations": 50,
    "human_eval_participants": 30,
    "create_visualizations": true
  }
}
